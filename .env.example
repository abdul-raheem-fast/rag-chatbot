# ============================================
# RAG Chatbot - Environment Configuration
# Copy this file to .env and fill in values
# ============================================

# --- App ---
APP_NAME="RAG Chatbot"
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# --- Database ---
# For local dev (SQLite, no PostgreSQL needed):
DATABASE_URL=sqlite+aiosqlite:///./ragchatbot.db
# For Docker/production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://raguser:ragpass@localhost:5432/ragchatbot

# --- Redis (optional — app works without it) ---
REDIS_URL=redis://localhost:6379/0

# --- ChromaDB ---
# "local" = in-process persistent storage (no separate server needed)
CHROMA_HOST=local
CHROMA_PORT=8100
CHROMA_COLLECTION=rag_documents

# --- LLM Providers (set at least one API key) ---
# Supported: openai, anthropic, google
DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Default models per provider
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GOOGLE_MODEL=gemini-1.5-flash

# --- Embeddings ---
# "local" = free ONNX MiniLM (no API key needed, runs on CPU)
# "openai" = OpenAI text-embedding-3-small (requires OPENAI_API_KEY)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Retrieval ---
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
SIMILARITY_THRESHOLD=0.72
RERANK_THRESHOLD=0.25
MAX_CONTEXT_TOKENS=6000
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- Auth ---
JWT_SECRET=change-me-to-another-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=30
DAILY_TOKEN_BUDGET=500000
MONTHLY_TOKEN_BUDGET=10000000

# --- Integrations (all optional) ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
GOOGLE_SHEETS_CREDENTIALS_JSON={}
GOOGLE_SHEETS_SPREADSHEET_ID=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@yourcompany.com
NOTION_API_TOKEN=

# --- Observability ---
LOG_LEVEL=INFO
